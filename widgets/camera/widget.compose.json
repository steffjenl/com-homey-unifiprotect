{
  "name": {
    "en": "Camera",
    "nl": "Camera"
  },
  "height": 270,
  "settings": [
    {
      "id": "device",
      "type": "autocomplete",
      "title": {
        "en": "Camera",
        "nl": "Camera"
      }
    },
    {
      "id": "enableLiveSnapshot",
      "type": "checkbox",
      "value": true,
      "title": {
        "en": "Live snapshot (requires local network access)",
        "nl": "Live snapshot (vereist lokaal netwerktoegang)"
      }
    },
    {
      "id": "refreshInterval",
      "type": "number",
      "value": 2,
      "min": 1,
      "max": 60,
      "title": {
        "en": "Refresh every (seconds)",
        "nl": "Ververs elke (seconden)"
      }
    }
  ],
  "api": {
    "getSnapshotUrl": {
      "method": "GET",
      "path": "/"
    },
    "getSnapshot": {
      "method": "GET",
      "path": "/snapshot"
    }
  }
}
