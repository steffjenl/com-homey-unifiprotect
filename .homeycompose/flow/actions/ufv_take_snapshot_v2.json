{
  "id": "ufv_take_snapshot_v2",
  "title": {
    "en": "Take a snapshot",
    "nl": "Maak een momentopname"
  },
  "titleFormatted": {
    "en": "Take a snapshot from [[device]] with an width from [[width]]"
  },
  "args": [
    {
      "title": {
        "en": "Camera"
      },
      "name": "device",
      "type": "device",
      "$filter": "driver_id=protectdoorbell|protectcamera"
    },
    {
      "title": {
        "en": "Width in pixels",
        "nl": "Breedte in pixels"
      },
      "name": "width",
      "type": "number",
      "min": 0,
      "max": 3840,
      "placeholder": {
        "en": "Width in pixels",
        "nl": "Breedte in pixels"
      }
    }
  ]
}
